{
  "name": "vibe-halo",
  "version": "0.4.0",
  "description": "A Windows dynamic-island approval, input, and completion surface for AI coding clients.",
  "main": "src/main.js",
  "type": "commonjs",
  "license": "AGPL-3.0-only",
  "author": "Vibe Halo contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/DaliBerr/Vibe-Halo.git"
  },
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "build": "electron-builder --config electron-builder.config.cjs --win nsis:x64 --publish never",
    "build:dir": "electron-builder --config electron-builder.config.cjs --win dir:x64 --publish never",
    "build:prepackaged": "electron-builder --config electron-builder.config.cjs --prepackaged dist/win-unpacked --win nsis --x64 --publish never",
    "release:metadata": "node scripts/generate-update-metadata.js"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "koffi": "^2.15.2"
  }
}
