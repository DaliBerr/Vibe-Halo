{
  "name": "vibe-halo",
  "version": "0.5.5",
  "description": "A cross-platform dynamic-island approval, input, and completion surface for AI coding clients.",
  "main": "src/main.js",
  "type": "commonjs",
  "license": "AGPL-3.0-only",
  "author": "Vibe Halo contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/DaliBerr/Vibe-Halo.git"
  },
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "icons": "node scripts/generate-icons.js",
    "prebuild": "npm run icons",
    "prebuild:dir": "npm run icons",
    "prebuild:win": "npm run icons",
    "prebuild:mac:arm64": "npm run icons",
    "prebuild:mac:x64": "npm run icons",
    "prebuild:linux:x64": "npm run icons",
    "build": "electron-builder --config electron-builder.config.cjs --publish never",
    "build:dir": "electron-builder --config electron-builder.config.cjs --dir --publish never",
    "build:win": "electron-builder --config electron-builder.config.cjs --win nsis:x64 --publish never",
    "build:mac:arm64": "electron-builder --config electron-builder.config.cjs --mac dmg zip --arm64 --publish never",
    "build:mac:x64": "electron-builder --config electron-builder.config.cjs --mac dmg zip --x64 --publish never",
    "build:linux:x64": "electron-builder --config electron-builder.config.cjs --linux AppImage deb --x64 --publish never",
    "verify:package": "node scripts/verify-packaged-app.js",
    "build:prepackaged": "electron-builder --config electron-builder.config.cjs --prepackaged dist/win-unpacked --win nsis --x64 --publish never",
    "release:metadata": "node scripts/generate-update-metadata.js"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "koffi": "^2.15.2"
  }
}
